 "cells": [
  {
   "metadata": {},
   "cell_type": "raw",
   "source": [
    "{\n",
    " \"cells\": [\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"# freebSEngine 快速入门\\n\",\n",
    "    \"\\n\",\n",
    "    \"这是一个 Jupyter notebook 示例，展示如何使用 freebSEngine 进行天体物理模拟。\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## 1. 安装和导入\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"# 安装 freebSEngine（如果尚未安装）\\n\",\n",
    "    \"# !pip install freebSEngine\\n\",\n",
    "    \"\\n\",\n",
    "    \"# 导入必要的库\\n\",\n",
    "    \"import freebSEngine as fse\\n\",\n",
    "    \"import numpy as np\\n\",\n",
    "    \"import matplotlib.pyplot as plt\\n\",\n",
    "    \"\\n\",\n",
    "    \"# 设置中文字体和图表样式\\n\",\n",
    "    \"plt.rcParams['font.sans-serif'] = ['SimHei', 'DejaVu Sans']\\n\",\n",
    "    \"plt.rcParams['axes.unicode_minus'] = False\\n\",\n",
    "    \"%matplotlib inline\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## 2. 基本常量\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"print(\\\"物理常量:\\\")\\n\",\n",
    "    \"print(f\\\"引力常数 G = {fse.GRAVITATIONAL_CONSTANT:.3e} m³/kg/s²\\\")\\n\",\n",
    "    \"print(f\\\"天文单位 AU = {fse.ASTRONOMICAL_UNIT:.3e} m\\\")\\n\",\n",
    "    \"print(f\\\"太阳质量 M☉ = {fse.SOLAR_MASS:.3e} kg\\\")\\n\",\n",
    "    \"print(f\\\"地球质量 M⊕ = {fse.EARTH_MASS:.3e} kg\\\")\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## 3. 计算地球轨道\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"# 地球轨道参数\\n\",\n",
    "    \"r0 = [1.496e11, 0.0, 0.0]  # 初始位置 (1 AU)\\n\",\n",
    "    \"v0 = [0.0, 29780.0, 0.0]   # 初始速度 (地球轨道速度)\\n\",\n",
    "    \"\\n\",\n",
    "    \"# 计算一年的轨道（365天，每天1步）\\n\",\n",
    "    \"positions = fse.propagate_orbit(r0, v0, epoch=0.0, step_seconds=24*3600, num_steps=365)\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(f\\\"轨道位置数组形状: {positions.shape}\\\")\\n\",\n",
    "    \"print(f\\\"第一天的位置: {positions[0] / 1e11:.3f} × 10¹¹ m\\\")\\n\",\n",
    "    \"print(f\\\"最后一天的位置: {positions[-1] / 1e11:.3f} × 10¹¹ m\\\")\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## 4. 可视化地球轨道\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"# 提取 x, y 坐标\\n\",\n",
    "    \"x = positions[:, 0] / fse.ASTRONOMICAL_UNIT  # 转换为 AU\\n\",\n",
    "    \"y = positions[:, 1] / fse.ASTRONOMICAL_UNIT\\n\",\n",
    "    \"\\n\",\n",
    "    \"# 创建图表\\n\",\n",
    "    \"plt.figure(figsize=(10, 8))\\n\",\n",
    "    \"\\n\",\n",
    "    \"# 绘制轨道\\n\",\n",
    "    \"plt.plot(x, y, 'b-', alpha=0.7, linewidth=1.5, label='地球轨道')\\n\",\n",
    "    \"plt.scatter(x[0], y[0], c='green', s=100, label='起点 (春分点)', zorder=5)\\n\",\n",
    "    \"plt.scatter(x[-1], y[-1], c='red', s=100, label='终点 (一年后)', zorder=5)\\n\",\n",
    "    \"\\n\",\n",
    "    \"# 绘制太阳\\n\",\n",
    "    \"plt.scatter(0, 0, c='orange', s=300, label='太阳', marker='*', edgecolors='red', linewidth=2)\\n\",\n",
    "    \"\\n\",\n",
    "    \"# 设置图表\\n\",\n",
    "    \"plt.axhline(y=0, color='gray', linestyle='--', alpha=0.5)\\n\",\n",
    "    \"plt.axvline(x=0, color='gray', linestyle='--', alpha=0.5)\\n\",\n",
    "    \"plt.xlabel('X 位置 (AU)')\\n\",\n",
    "    \"plt.ylabel('Y 位置 (AU)')\\n\",\n",
    "    \"plt.title('地球绕太阳轨道 (一年模拟)')\\n\",\n",
    "    \"plt.legend()\\n\",\n",
    "    \"plt.grid(True, alpha=0.3)\\n\",\n",
    "    \"plt.axis('equal')\\n\",\n",
    "    \"\\n\",\n",
    "    \"plt.show()\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## 5. 计算轨道根数\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"# 计算开普勒轨道根数\\n\",\n",
    "    \"elements = fse.compute_keplerian_elements(r0, v0, epoch=0.0)\\n\",\n",
    "    \"\\n\",\n",
    "    \"element_names = [\\n\",\n",
    "    \"    '半长轴 (a)',\\n\",\n",
    "    \"    '偏心率 (e)',\\n\",\n",
    "    \"    '倾角 (i)',\\n\",\n",
    "    \"    '升交点赤经 (Ω)',\\n\",\n",
    "    \"    '近地点幅角 (ω)',\\n\",\n",
    "    \"    '真近点角 (ν)'\\n\",\n",
    "    \"]\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(\\\"地球轨道根数:\\\")\\n\",\n",
    "    \"for name, value in zip(element_names, elements):\\n\",\n",
    "    \"    if name == '半长轴 (a)':\\n\",\n",
    "    \"        print(f\\\"  {name}: {value / fse.ASTRONOMICAL_UNIT:.6f} AU ({value:.3e} m)\\\")\\n\",\n",
    "    \"    elif name == '偏心率 (e)':\\n\",\n",
    "    \"        print(f\\\"  {name}: {value:.6f}\\\")\\n\",\n",
    "    \"    else:\\n\",\n",
    "    \"        print(f\\\"  {name}: {value:.2f}°\\\")\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## 6. 使用天体对象\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"from freebSEngine.celestial_objects import SUN, EARTH, MARS, get_body\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(\\\"太阳系天体信息:\\\")\\n\",\n",
    "    \"print(f\\\"太阳: 质量={SUN.mass/fse.SOLAR_MASS:.3f} M☉, 半径={SUN.radius/1e9:.1f} × 10⁹ m\\\")\\n\",\n",
    "    \"print(f\\\"地球: 质量={EARTH.mass/fse.EARTH_MASS:.3f} M⊕, 半径={EARTH.radius/1e6:.1f} × 10⁶ m\\\")\\n\",\n",
    "    \"print(f\\\"火星: 质量={MARS.mass/fse.EARTH_MASS:.3f} M⊕, 半径={MARS.radius/1e6:.1f} × 10⁶ m\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"# 计算逃逸速度\\n\",\n",
    "    \"earth_escape = fse.escape_velocity(EARTH.radius, EARTH.mass)\\n\",\n",
    "    \"print(f\\\"\\\\n地球逃逸速度: {earth_escape/1000:.2f} km/s\\\")\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## 7. 轨道计算工具\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"from freebSEngine.utils import (\\n\",\n",
    "    \"    au_to_meters, meters_to_au,\\n\",\n",
    "    \"    circular_orbit_velocity, orbital_period\\n\",\n",
    "    \")\\n\",\n",
    "    \"\\n\",\n",
    "    \"# 单位转换\\n\",\n",
    "    \"distance_au = 1.5\\n\",\n",
    "    \"distance_m = au_to_meters(distance_au)\\n\",\n",
    "    \"print(f\\\"{distance_au} AU = {distance_m:.3e} m\\\")\\n\",\n",
    "    \"print(f\\\"{distance_m:.3e} m = {meters_to_au(distance_m):.6f} AU\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"# 计算圆形轨道速度\\n\",\n",
    "    \"earth_orbit_radius = 1.496e11  # 1 AU\\n\",\n",
    "    \"earth_velocity = fse.circular_orbit_velocity(earth_orbit_radius, SUN.mass)\\n\",\n",
    "    \"print(f\\\"\\\\n地球圆形轨道速度: {earth_velocity/1000:.2f} km/s\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"# 计算轨道周期\\n\",\n",
    "    \"sun_mu = SUN.gravitational_parameter\\n\",\n",
    "    \"earth_period = fse.orbital_period(earth_orbit_radius, sun_mu)\\n\",\n",
    "    \"print(f\\\"地球轨道周期: {earth_period/(24*3600):.2f} 天\\\")\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## 8. 简单 N 体模拟\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"# 创建一个简单的双星系统\\n\",\n",
    "    \"positions = [\\n\",\n",
    "    \"    [0.0, 0.0, 0.0],           # 主星在原点\\n\",\n",
    "    \"    [1.496e11, 0.0, 0.0],      # 伴星在 1 AU 处\\n\",\n",
    "    \"]\\n\",\n",
    "    \"\\n\",\n",
    "    \"velocities = [\\n\",\n",
    "    \"    [0.0, 0.0, 0.0],           # 主星静止\\n\",\n",
    "    \"    [0.0, 29780.0, 0.0],       # 伴星轨道速度\\n\",\n",
    "    \"]\\n\",\n",
    "    \"\\n\",\n",
    "    \"masses = [\\n\",\n",
    "    \"    SUN.mass,                   # 太阳质量\\n\",\n",
    "    \"    0.1 * SUN.mass,             # 小伴星质量\\n\",\n",
    "    \"]\\n\",\n",
    "    \"\\n\",\n",
    "    \"# 运行短时间模拟\\n\",\n",
    "    \"print(\\\"运行双星系统模拟...\\\")\\n\",\n",
    "    \"all_positions = fse.nbody_simulation(\\n\",\n",
    "    \"    positions, velocities, masses,\\n\",\n",
    "    \"    epoch=0.0, dt=24*3600, steps=30  # 30天模拟\\n\",\n",
    "    \")\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(f\\\"模拟完成! 结果形状: {all_positions.shape}\\\")\\n\",\n",
    "    \"print(f\\\"主星最终位置: {all_positions[-1, 0] / 1e11:.3f} × 10¹¹ m\\\")\\n\",\n",
    "    \"print(f\\\"伴星最终位置: {all_positions[-1, 1] / 1e11:.3f} × 10¹¹ m\\\")\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## 9. 可视化 N 体模拟\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"# 提取两个天体的轨迹\\n\",\n",
    "    \"primary_traj = all_positions[:, 0, :2] / fse.ASTRONOMICAL_UNIT  # 只取 x,y\\n\",\n",
    "    \"secondary_traj = all_positions[:, 1, :2] / fse.ASTRONOMICAL_UNIT\\n\",\n",
    "    \"\\n\",\n",
    "    \"# 创建图表\\n\",\n",
    "    \"plt.figure(figsize=(12, 10))\\n\",\n",
    "    \"\\n\",\n",
    "    \"# 绘制轨迹\\n\",\n",
    "    \"plt.plot(primary_traj[:, 0], primary_traj[:, 1], 'r-', alpha=0.5, linewidth=2, label='主星轨迹')\\n\",\n",
    "    \"plt.plot(secondary_traj[:, 0], secondary_traj[:, 1], 'b-', alpha=0.5, linewidth=2, label='伴星轨迹')\\n\",\n",
    "    \"\\n\",\n",
    "    \"# 绘制起点和终点\\n\",\n",
    "    \"plt.scatter(primary_traj[0, 0], primary_traj[0, 1], c='darkred', s=150, label='主星起点', zorder=5)\\n\",\n",
    "    \"plt.scatter(secondary_traj[0, 0], secondary_traj[0, 1], c='darkblue', s=150, label='伴星起点', zorder=5)\\n\",\n",
    "    \"plt.scatter(primary_traj[-1, 0], primary_traj[-1, 1], c='red', s=200, marker='*', label='主星终点', zorder=5)\\n\",\n",
    "    \"plt.scatter(secondary_traj[-1, 0], secondary_traj[-1, 1], c='blue', s=200, marker='*', label='伴星终点', zorder=5)\\n\",\n",
    "    \"\\n\",\n",
    "    \"# 设置图表\\n\",\n",
    "    \"plt.axhline(y=0, color='gray', linestyle='--', alpha=0.3)\\n\",\n",
    "    \"plt.axvline(x=0, color='gray', linestyle='--', alpha=0.3)\\n\",\n",
    "    \"plt.xlabel('X 位置 (AU)')\\n\",\n",
    "    \"plt.ylabel('Y 位置 (AU)')\\n\",\n",
    "    \"plt.title('双星系统模拟 (30天)')\\n\",\n",
    "    \"plt.legend(loc='upper right')\\n\",\n",
    "    \"plt.grid(True, alpha=0.2)\\n\",\n",
    "    \"plt.axis('equal')\\n\",\n",
    "    \"\\n\",\n",
    "    \"plt.show()\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## 10. 总结\\n\",\n",
    "    \"\\n\",\n",
    "    \"freebSEngine 提供了以下功能：\\n\",\n",
    "    \"\\n\",\n",
    "    \"1. **高性能轨道计算**：使用 Rust 实现的核心算法\\n\",\n",
    "    \"2. **完整的天体物理工具**：轨道传播、N体模拟、开普勒元素计算\\n\",\n",
    "    \"3. **丰富的天体数据库**：太阳系主要天体的物理参数\\n\",\n",
    "    \"4. **实用的工具函数**：单位转换、轨道计算、坐标转换\\n\",\n",
    "    \"5. **可视化支持**：与 matplotlib 等库无缝集成\\n\",\n",
    "    \"\\n\",\n",
    "    \"### 下一步\\n\",\n",
    "    \"\\n\",\n",
    "    \"- 尝试运行可视化演示：`python -m freebSEngine.demo`\\n\",\n",
    "    \"- 查看高级功能：`from freebSEngine.advanced_mechanics import AdvancedOrbitalMechanics`\\n\",\n",
    "    \"- 运行性能基准测试：`python benchmarks/benchmark_basic.py`\\n\",\n",
    "    \"- 阅读完整文档：查看 README.md 和代码文档\"\n",
    "   ]\n",
    "  }\n",
    " ],\n",
